{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "anytype": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@anyproto/anytype-mcp"],
      "environment": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer <YOUR_API_KEY>\", \"Anytype-Version\":\"2025-11-08\"}"
      }
    }
  },

  "plugins": {
    "anytype-mind": {
      "enabled": true
    }
  },

  "permission": {
    "bash": {
      "*": "ask",
      "bash .opencode/scripts/*": "allow",
      "python3 .opencode/scripts/*": "allow",
      "python .opencode/scripts/*": "allow",
      "curl http://localhost:31009/*": "allow",
      "date": "allow",
      "date *": "allow",
      "gh pr *": "ask",
      "gh pr list *": "allow",
      "gh pr view *": "allow"
    },
    "webfetch": "allow"
  }
}
